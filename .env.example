IMMICH_BASE_URL=http://localhost:2283
IMMICH_API_KEY=replace-with-your-immich-api-key
PORT=3001

# Optional Gemini integration
GEMINI_API_KEY=replace-with-your-gemini-api-key

# Optional service/config overrides
WEATHER_PROVIDER=open-meteo
WEATHER_BASE_URL=
OVERPASS_BASE_URL=
MAP_DEFAULT_ZOOM=15
MAP_POI_RADIUS_METERS=1000

# Paperless-ngx document archive
PAPERLESS_BASE_URL=http://localhost:8000
PAPERLESS_API_TOKEN=replace-with-your-paperless-token

# Document semantic search (Qdrant)
DOCUMENT_VECTOR_ENABLED=false
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
DOCUMENT_VECTOR_COLLECTION=documents
DOCUMENT_EMBEDDING_PROVIDER=gemini
DOCUMENT_EMBEDDING_MODEL=gemini-embedding-001
DOCUMENT_EMBEDDING_API_KEY=
DOCUMENT_EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta
DOCUMENT_INDEX_BATCH_SIZE=100
DOCUMENT_SCHEDULER_BATCH_SIZE=5
DOCUMENT_INDEX_CHUNK_SIZE=1600
DOCUMENT_INDEX_CHUNK_OVERLAP=150
VECTOR_SCHEMA_VERSION=v1

# Ollama example instead of Gemini:
# DOCUMENT_EMBEDDING_PROVIDER=ollama
# DOCUMENT_EMBEDDING_MODEL=nomic-embed-text
# DOCUMENT_EMBEDDING_BASE_URL=http://localhost:11434/v1
